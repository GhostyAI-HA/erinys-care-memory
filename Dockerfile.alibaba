FROM node:20-slim AS web-build

WORKDIR /web

COPY web/package*.json ./
RUN npm ci

COPY web ./
RUN npm run build

FROM python:3.13-slim

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY data ./data
COPY --from=web-build /web/dist ./web/dist

RUN python -m pip install --no-cache-dir .

ENV QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ENV QWEN_MODEL=qwen3.7-plus
ENV ERINYS_USE_MOCK_QWEN=false
ENV ERINYS_DEMO_SEED=/app/data/demo/care_memory.seed.json
ENV ERINYS_MEMORY_STORE=/tmp/runtime_memory.json
ENV ERINYS_WEB_DIST=/app/web/dist
ENV ERINYS_ALLOWED_ORIGINS=
ENV PORT=8000

EXPOSE 8000

CMD ["sh", "-c", "uvicorn erinys_qwen_agent.api:app --host 0.0.0.0 --port ${PORT:-8000}"]
